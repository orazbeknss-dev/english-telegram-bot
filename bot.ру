# ==================== КӨМЕКШІ ФУНКЦИЯЛАР ====================
def get_groq_response(system_prompt: str, user_message: str, user_level: str = "B1") -> str:
    try:
        full_system_prompt = f"""You are an English teacher for a student at {user_level} level.
{system_prompt}

Guidelines:
- Respond in English only
- Use vocabulary appropriate for {user_level} level
- Be encouraging and helpful
- Keep responses concise (2-4 sentences)"""
        
        response = groq_client.chat.completions.create(
            model="llama3-70b-8192",
            messages=[
                {"role": "system", "content": full_system_prompt},
                {"role": "user", "content": user_message}
            ],
            temperature=0.7,
            max_tokens=300
        )
        return response.choices[0].message.content
    except Exception as e:
        logger.error(f"Groq API қатесі: {e}")
        return "Sorry, I'm having trouble responding. Please try again."

def create_audio(text: str, filename: str) -> str:
    try:
        if not os.path.exists('audio_files'):
            os.makedirs('audio_files')
        
        filepath = f"audio_files/{filename}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.mp3"
        tts = gTTS(text=text, lang='en', slow=False)
        tts.save(filepath)
        return filepath
    except Exception as e:
        logger.error(f"Аудио жасау қатесі: {e}")
        return None

