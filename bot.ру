async def chat_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    user_message = update.message.text
    
    if not context.user_data.get('chat_mode', False):
        await update.message.reply_text("👋 Сөйлесу режимін қосу үшін /start -> 'Ағылшынша сөйлесу'")
        return
    
    if user_id not in user_data:
        user_data[user_id] = {"level": "A2", "topic": "General"}
    
    level = user_data[user_id].get("level", "A2")
    topic = user_data[user_id].get("topic", "General")
    
    system_prompt = f"You are an English teacher. Student level: {level}. Topic: {topic}. Correct mistakes gently."
    
    thinking = await update.message.reply_text("🤔 Thinking...")
    response = get_groq_response(system_prompt, user_message, level)
    await thinking.delete()
    await update.message.reply_text(f"👩‍🏫 *Teacher:* {response}", parse_mode='Markdown')

async def stop_chat(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data['chat_mode'] = False
    await update.message.reply_text("✅ Сөйлесу режимі тоқтатылды. /start арқылы қайта бастаңыз.")

